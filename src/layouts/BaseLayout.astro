---
import '../styles/global.css';
import SEO from '../components/SEO.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE } from '../data/site';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  image?: string;
  type?: 'website' | 'article';
  schema?: Record<string, unknown> | Record<string, unknown>[];
}

const props = Astro.props;

const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: SITE.name,
  url: SITE.url,
  description: SITE.tagline,
  publisher: {
    '@type': 'Organization',
    name: SITE.name,
    url: SITE.url,
  },
};
---

<!doctype html>
<html lang="en">
  <head>
    <SEO {...props} schema={[orgSchema, ...(props.schema ? (Array.isArray(props.schema) ? props.schema : [props.schema]) : [])]} />
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
